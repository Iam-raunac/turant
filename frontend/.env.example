# Copy this file to .env.local and fill in your API Gateway invoke URL.
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com/prod/parse-cart
VITE_API_URL=

# Optional: set to "1" to use the bundled mock backend instead of calling AWS.
# Useful for offline demo / fallback if Lambda is unreachable.
VITE_USE_MOCK=0
